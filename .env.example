.env.example
# FastAPI Configuration
FASTAPI_HOST=0.0.0.0
FASTAPI_PORT=8000
SECRET_KEY=your-secret-key-change-in-production
ENVIRONMENT=development
DEBUG=True

# Database Configuration
DB_USER=pimp
DB_PASSWORD=pimp_secure_pwd
DB_NAME=pimp_db
DB_HOST=localhost
DB_PORT=5432
DATABASE_URL=postgresql://pimp:pimp_secure_pwd@localhost:5432/pimp_db

# Redis Configuration
REDIS_URL=redis://localhost:6379/0
REDIS_EXPIRE_TIME=3600

# Logging
LOG_LEVEL=INFO
LOG_FILE=logs/pimp.log

# External APIs - Reddit
REDDIT_CLIENT_ID=your-reddit-client-id
REDDIT_CLIENT_SECRET=your-reddit-client-secret
REDDIT_USER_AGENT=PIMP/1.0 (by aabc25891-ops)
REDDIT_UPDATE_FREQUENCY=6

# E-commerce Update Frequency
AMAZON_UPDATE_FREQUENCY=24
FLIPKART_UPDATE_FREQUENCY=24
MEESHO_UPDATE_FREQUENCY=24

# Sentry Configuration (Optional)
SENTRY_DSN=

# CORS Configuration
CORS_ORIGINS=*

# Rate Limiting
RATE_LIMIT_ENABLED=True
RATE_LIMIT_PER_MINUTE=100
