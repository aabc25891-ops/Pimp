# PIMP Configuration File
# Copy this to .env and fill in your API keys

# Database Configuration
DATABASE_URL=postgresql://username:password@localhost:5432/pimp_db
DATABASE_HOST=localhost
DATABASE_PORT=5432
DATABASE_NAME=pimp_db
DATABASE_USER=pimp_user
DATABASE_PASSWORD=your_secure_password

# Google Trends API
GOOGLE_API_KEY=your_google_api_key_here
GOOGLE_SEARCH_ENGINE_ID=your_search_engine_id_here

# Reddit API
REDDIT_CLIENT_ID=your_reddit_client_id
REDDIT_CLIENT_SECRET=your_reddit_client_secret
REDDIT_USER_AGENT=PIMP/1.0

# YouTube API
YOUTUBE_API_KEY=your_youtube_api_key

# Instagram (if using instagrapi)
INSTAGRAM_USERNAME=your_instagram_username
INSTAGRAM_PASSWORD=your_instagram_password

# FastAPI Configuration
FASTAPI_HOST=0.0.0.0
FASTAPI_PORT=8000
FASTAPI_DEBUG=True
SECRET_KEY=your_secret_key_for_jwt_tokens

# Airflow Configuration
AIRFLOW_HOME=/home/airflow/airflow
AIRFLOW__CORE__DAGS_FOLDER=/app/airflow/dags
AIRFLOW__CORE__LOAD_EXAMPLES=False
AIRFLOW__CORE__UNIT_TEST_MODE=False

# Redis Configuration (for caching & task queue)
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0
REDIS_PASSWORD=

# Email Notifications
SMTP_SERVER=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=your_email@gmail.com
SMTP_PASSWORD=your_app_password
NOTIFICATION_EMAIL=alerts@example.com

# Data Collection Settings
SCRAPE_SCHEDULE=0 2 * * *  # 2 AM IST daily
MEESHO_UPDATE_FREQUENCY=24  # hours
AMAZON_UPDATE_FREQUENCY=24  # hours
FLIPKART_UPDATE_FREQUENCY=24  # hours
REDDIT_UPDATE_FREQUENCY=6   # hours

# ML Model Settings
FORECAST_HORIZON=30  # days
CONFIDENCE_THRESHOLD=0.6
MIN_DATA_POINTS=30  # minimum historical data for forecasting

# Logging
LOG_LEVEL=INFO
LOG_FILE=logs/pimp.log

# Environment
ENVIRONMENT=development  # development, staging, production
DEBUG=True

# AWS (if deploying to AWS)
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=us-east-1
AWS_S3_BUCKET=pimp-data

# Sentry (Error tracking)
SENTRY_DSN=

# Categories to Track
CATEGORIES=Fashion,Home Goods
MEESHO_CATEGORY_IDS=1,2
AMAZON_CATEGORY_IDS=1,2
FLIPKART_CATEGORY_IDS=1,2

# Proxy Settings (optional, for scraping)
USE_PROXY=False
PROXY_LIST=

# Rate Limiting
API_RATE_LIMIT=100
SCRAPER_DELAY=2  # seconds between requests
